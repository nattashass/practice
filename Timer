public class Timer extends Thread {
    @Override
    public void run() {
        int seconds = 0;
        while (true) {
            System.out.println("Час" + seconds + "c");
            seconds++;
            try {
                Thread.sleep(1000);
            } catch (InterruptedException e ) {
                System.out.println("Помилка потоку: " + e.getMessage());

            }

        }
    }
    public static void main(String[] args) {
        Timer timer = new Timer();
        timer.start();
    }
}
