/**
 * Клас StudentInfo зберігає інформацію про студента
 */
class StudentInfo {

    private String name;
    private int age;
    private String specialty;

    /**
     * Конструктор класу StudentInfo
     * @param name ім’я студента
     * @param age вік студента
     * @param specialty спеціальність студента
     */
    public StudentInfo(String name, int age, String specialty) {
        this.name = name;
        this.age = age;
        this.specialty = specialty;
    }

    /**
     * Метод для виведення інформації про студента
     */
    public void displayInfo() {
        System.out.println("Ім’я: " + name);
        System.out.println("Вік: " + age);
        System.out.println("Спеціальність: " + specialty);
    }
}

/**
 * Головний клас програми
 */
public class Student {

    /**
     * Головний метод запуску програми
     * @param args аргументи командного рядка
     */
    public static void main(String[] args) {

        StudentInfo student = new StudentInfo(
                "Дарина",
                17,
                "Програмування"
        );

        student.displayInfo();
    }
}
